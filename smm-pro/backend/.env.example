# ================================
# SMM PRO - Environment Variables
# ================================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/smm-pro

# JWT
JWT_SECRET=your_very_long_secret_key_here_min_32_chars
JWT_EXPIRES_IN=7d

# ---- YOUTUBE (Google API) ----
# Buat project di: https://console.cloud.google.com
# Enable: YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:5000/api/auth/youtube/callback

# ---- INSTAGRAM & FACEBOOK (Meta) ----
# Buat app di: https://developers.facebook.com
# Permissions: pages_manage_posts, instagram_content_publish, pages_read_engagement
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:5000/api/auth/meta/callback

# ---- X / TWITTER ----
# Buat app di: https://developer.twitter.com
# OAuth 2.0 diperlukan (bukan OAuth 1.0a)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:5000/api/auth/twitter/callback

# ---- TIKTOK ----
# Buat app di: https://developers.tiktok.com
# Scope: video.upload, video.list
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:5000/api/auth/tiktok/callback

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=104857600
