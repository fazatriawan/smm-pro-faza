{
  "name": "smm-pro-desktop",
  "version": "2.0.0",
  "description": "SMM Pro Desktop - Social Media Management & Automation",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win",
    "dev": "electron . --dev"
  },
  "build": {
    "appId": "com.smmpro.desktop",
    "productName": "SMM Pro Desktop",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": ["src/**/*", "assets/**/*", "!**/node_modules/*/{CHANGELOG.md,README.md}"]
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
