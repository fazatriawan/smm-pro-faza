{
  "name": "smm-pro-desktop",
  "version": "2.0.0",
  "description": "SMM Pro Desktop - Social Media Management & Automation",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "cd src/renderer-react && npm run build && cd ../.. && electron-builder build --win",
    "dev": "electron . --dev"
  },
  "build": {
    "appId": "com.smmpro.desktop",
    "productName": "SMM Pro Desktop",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "src/main/**/*",
      "src/services/**/*",
      "src/automation/**/*",
      "src/renderer-react/dist/**/*",
      "assets/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@supabase/supabase-js": "^2.103.3",
    "axios": "^1.6.0",
    "dotenv": "^17.4.2",
    "electron-store": "^8.1.0",
    "node-fetch": "^2.7.0",
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
